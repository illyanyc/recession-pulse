{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "X-DNS-Prefetch-Control", "value": "on" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    },
    {
      "source": "/embed/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "ALLOWALL" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/fetch-indicators",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/cron/screen-stocks",
      "schedule": "5 11 * * 1-5"
    },
    {
      "path": "/api/cron/analyze-risk",
      "schedule": "30 11 * * *"
    },
    {
      "path": "/api/cron/send-alerts",
      "schedule": "15 12 * * *"
    },
    {
      "path": "/api/cron/post-daily-tweet",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/post-market-open",
      "schedule": "30 14 * * 1-5"
    },
    {
      "path": "/api/cron/post-educational",
      "schedule": "0 17 * * *"
    },
    {
      "path": "/api/cron/post-engagement",
      "schedule": "0 20 * * *"
    },
    {
      "path": "/api/cron/send-newsletter",
      "schedule": "15 21 * * 5"
    },
    {
      "path": "/api/cron/post-cta",
      "schedule": "0 23 * * *"
    },
    {
      "path": "/api/cron/generate-content",
      "schedule": "0 14 * * 0"
    },
    {
      "path": "/api/cron/post-weekly-thread",
      "schedule": "0 22 * * 0"
    }
  ]
}
